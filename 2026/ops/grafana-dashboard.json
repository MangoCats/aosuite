  "panels": [
    {
      "title": "Recorder — Block Submissions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(recorder_blocks_submitted_total{status=\"ok\"}[5m])",
          "legendFormat": "blocks/s (ok)"
        },
        {
          "expr": "rate(recorder_blocks_submitted_total{status=\"error\"}[5m])",
          "legendFormat": "blocks/s (error)"
        }
      ]
    },
    {
      "title": "Recorder — Block Submit Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(recorder_block_submit_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(recorder_block_submit_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(recorder_block_submit_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Recorder — Blob Uploads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(recorder_blobs_uploaded_total[5m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Recorder — Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
