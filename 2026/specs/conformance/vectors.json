{
  "_comment": "Assign Onward conformance test vectors — Phase 0E. All hex strings are lowercase, no 0x prefix.",
  "_spec_refs": {
    "vbc": "WireFormat.md §1",
    "bigint": "WireFormat.md §4",
    "rational": "WireFormat.md §4.3",
    "timestamp": "WireFormat.md §5",
    "fee": "EconomicRules.md §3",
    "expiration": "EconomicRules.md §4"
  },

  "vbc_signed": {
    "_description": "Signed VBC: n >= 0 → wire = n<<1; n < 0 → wire = ((-n)<<1)|1. Then encode wire as unsigned VBC (LSB-first, 7 bits/byte, bit 7 = continuation).",
    "vectors": [
      { "value": 0,        "wire": 0,      "hex": "00", "note": "zero" },
      { "value": 1,        "wire": 2,      "hex": "02", "note": "smallest positive" },
      { "value": -1,       "wire": 3,      "hex": "03", "note": "smallest negative" },
      { "value": 2,        "wire": 4,      "hex": "04" },
      { "value": -2,       "wire": 5,      "hex": "05" },
      { "value": 3,        "wire": 6,      "hex": "06" },
      { "value": -3,       "wire": 7,      "hex": "07" },
      { "value": 10,       "wire": 20,     "hex": "14" },
      { "value": -10,      "wire": 21,     "hex": "15" },
      { "value": 31,       "wire": 62,     "hex": "3e" },
      { "value": -31,      "wire": 63,     "hex": "3f" },
      { "value": 32,       "wire": 64,     "hex": "40" },
      { "value": -32,      "wire": 65,     "hex": "41" },
      { "value": 63,       "wire": 126,    "hex": "7e", "note": "max single-byte positive" },
      { "value": -63,      "wire": 127,    "hex": "7f", "note": "max single-byte negative" },
      { "value": 64,       "wire": 128,    "hex": "8001", "note": "first 2-byte positive" },
      { "value": -64,      "wire": 129,    "hex": "8101", "note": "first 2-byte negative" },
      { "value": -65,      "wire": 131,    "hex": "8301" },
      { "value": 100,      "wire": 200,    "hex": "c801" },
      { "value": -100,     "wire": 201,    "hex": "c901" },
      { "value": 127,      "wire": 254,    "hex": "fe01" },
      { "value": 128,      "wire": 256,    "hex": "8002" },
      { "value": -128,     "wire": 257,    "hex": "8102" },
      { "value": 255,      "wire": 510,    "hex": "fe03" },
      { "value": -255,     "wire": 511,    "hex": "ff03" },
      { "value": 256,      "wire": 512,    "hex": "8004" },
      { "value": 1000,     "wire": 2000,   "hex": "d00f" },
      { "value": -1000,    "wire": 2001,   "hex": "d10f" },
      { "value": 8191,     "wire": 16382,  "hex": "fe7f", "note": "max 2-byte positive" },
      { "value": -8191,    "wire": 16383,  "hex": "ff7f", "note": "max 2-byte negative" },
      { "value": 8192,     "wire": 16384,  "hex": "808001", "note": "first 3-byte positive" },
      { "value": -8192,    "wire": 16385,  "hex": "818001", "note": "first 3-byte negative" },
      { "value": 1000000,  "wire": 2000000, "hex": "80897a", "note": "3 bytes" },
      { "value": -1000000, "wire": 2000001, "hex": "81897a", "note": "3 bytes" }
    ],
    "invalid": [
      { "hex": "01", "reason": "negative zero (wire value 1) is not permitted" }
    ]
  },

  "vbc_unsigned": {
    "_description": "Unsigned VBC: 7 data bits per byte (bits 0-6), bit 7 = continuation, LSB-first.",
    "vectors": [
      { "value": 0,     "hex": "00" },
      { "value": 1,     "hex": "01" },
      { "value": 2,     "hex": "02" },
      { "value": 63,    "hex": "3f" },
      { "value": 64,    "hex": "40" },
      { "value": 127,   "hex": "7f", "note": "max single-byte" },
      { "value": 128,   "hex": "8001", "note": "first 2-byte" },
      { "value": 255,   "hex": "ff01" },
      { "value": 256,   "hex": "8002" },
      { "value": 1000,  "hex": "e807" },
      { "value": 16383, "hex": "ff7f", "note": "max 2-byte" },
      { "value": 16384, "hex": "808001", "note": "first 3-byte" }
    ]
  },

  "bigint": {
    "_description": "Big integer encoding: unsigned VBC byte count + two's-complement big-endian magnitude. Zero = 0 bytes. MSB of first magnitude byte >= 0x80 means negative.",
    "vectors": [
      { "value": "0",     "byte_count": 0, "magnitude_hex": "",       "full_hex": "00" },
      { "value": "1",     "byte_count": 1, "magnitude_hex": "01",     "full_hex": "0101" },
      { "value": "-1",    "byte_count": 1, "magnitude_hex": "ff",     "full_hex": "01ff" },
      { "value": "127",   "byte_count": 1, "magnitude_hex": "7f",     "full_hex": "017f" },
      { "value": "-127",  "byte_count": 1, "magnitude_hex": "81",     "full_hex": "0181" },
      { "value": "128",   "byte_count": 2, "magnitude_hex": "0080",   "full_hex": "020080" },
      { "value": "-128",  "byte_count": 1, "magnitude_hex": "80",     "full_hex": "0180" },
      { "value": "-129",  "byte_count": 2, "magnitude_hex": "ff7f",   "full_hex": "02ff7f" },
      { "value": "255",   "byte_count": 2, "magnitude_hex": "00ff",   "full_hex": "0200ff" },
      { "value": "-255",  "byte_count": 2, "magnitude_hex": "ff01",   "full_hex": "02ff01" },
      { "value": "256",   "byte_count": 2, "magnitude_hex": "0100",   "full_hex": "020100" },
      { "value": "-256",  "byte_count": 2, "magnitude_hex": "ff00",   "full_hex": "02ff00" },
      { "value": "32767", "byte_count": 2, "magnitude_hex": "7fff",   "full_hex": "027fff" },
      { "value": "-32768","byte_count": 2, "magnitude_hex": "8000",   "full_hex": "028000" },
      { "value": "65535", "byte_count": 3, "magnitude_hex": "00ffff", "full_hex": "0300ffff" },
      { "value": "18446744073709551616",
        "byte_count": 9,
        "magnitude_hex": "010000000000000000",
        "full_hex": "09010000000000000000",
        "note": "2^64"
      },
      { "value": "77371252455336267181195264",
        "byte_count": 11,
        "magnitude_hex": "4000000000000000000000",
        "full_hex": "0b4000000000000000000000",
        "note": "~2^86 typical genesis share pool (exact: 2^86 = 4 * 2^84)"
      }
    ]
  },

  "rational": {
    "_description": "Rational fraction: TotalSize(unsigned VBC) + NumSize(unsigned VBC) + Numerator(two's complement BE) + Denominator(two's complement BE, must be positive). DenomSize = TotalSize - len(NumSize_vbc) - NumSize.",
    "vectors": [
      {
        "value": "1/2",
        "numerator": "1", "denominator": "2",
        "num_hex": "01", "denom_hex": "02",
        "full_hex": "03010102",
        "note": "TotalSize=3, NumSize=1, num=[01], denom=[02]"
      },
      {
        "value": "-3/7",
        "numerator": "-3", "denominator": "7",
        "num_hex": "fd", "denom_hex": "07",
        "full_hex": "0301fd07",
        "note": "TotalSize=3, NumSize=1, num=[fd], denom=[07]"
      },
      {
        "value": "1/1000000",
        "numerator": "1", "denominator": "1000000",
        "num_hex": "01", "denom_hex": "0f4240",
        "full_hex": "0501010f4240",
        "note": "TotalSize=5, NumSize=1, num=[01], denom=[0f4240]"
      },
      {
        "value": "3/10000000000",
        "numerator": "3", "denominator": "10000000000",
        "num_hex": "03", "denom_hex": "02540be400",
        "full_hex": "07010302540be400",
        "note": "typical fee rate: TotalSize=7, NumSize=1"
      }
    ]
  },

  "timestamp": {
    "_description": "AO timestamp = Unix_seconds * 189000000. Stored as 8-byte big-endian signed integer.",
    "multiplier": 189000000,
    "vectors": [
      {
        "description": "Unix epoch",
        "utc": "1970-01-01T00:00:00Z",
        "unix_seconds": 0,
        "ao_timestamp": 0,
        "hex": "0000000000000000"
      },
      {
        "description": "2024-01-01",
        "utc": "2024-01-01T00:00:00Z",
        "unix_seconds": 1704067200,
        "ao_timestamp_formula": "1704067200 * 189000000",
        "ao_timestamp": "322068700800000000",
        "hex": "047837c6e874a000"
      },
      {
        "description": "2026-01-01",
        "utc": "2026-01-01T00:00:00Z",
        "unix_seconds": 1767225600,
        "ao_timestamp_formula": "1767225600 * 189000000",
        "ao_timestamp": "334005638400000000",
        "hex": "04a2a05bc5cf4000"
      },
      {
        "description": "2026-03-06",
        "utc": "2026-03-06T00:00:00Z",
        "unix_seconds": 1772611200,
        "ao_timestamp_formula": "1772611200 * 189000000",
        "ao_timestamp": "335023516800000000",
        "hex": "04a63e1d0e442000"
      },
      {
        "description": "1-second resolution check",
        "utc": "1970-01-01T00:00:01Z",
        "unix_seconds": 1,
        "ao_timestamp": 189000000,
        "hex": "000000000b43e940"
      }
    ]
  },

