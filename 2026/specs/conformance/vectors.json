  "ed25519": {
    "_description": "Ed25519 test vectors from RFC 8032 §7.1. AO-specific: signed_data = SHA256(assignment_bytes) || timestamp_8bytes.",
    "rfc8032_test1": {
      "private_seed_hex": "9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60",
      "public_key_hex": "d75a980182b10ab7d54bfed3c964073a0ee172f3daa3f4a18446b0b8d558cd8d",
      "message_hex": "",
      "signature_hex": "e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b",
      "note": "RFC 8032 TEST 1 - empty message"
    },
    "ao_format_note": "In AO, the message signed is always 40 bytes: SHA256(substituted_assignment) || timestamp. Implementations should test Ed25519 with RFC 8032 vectors first, then test the AO signing pipeline end-to-end."
  },

  "fee_calculation": {
    "_description": "Recording fee: fee_shares = ceil(data_bytes * FEE_RATE_num * SHARES_OUT / FEE_RATE_den). ceil(a/b) = (a + b - 1) / b for positive integers.",
    "vectors": [
      {
        "description": "500 bytes, fresh genesis",
        "data_bytes": 500,
        "fee_rate_num": 1,
        "fee_rate_den": 1000000,
        "shares_out": "77371252455336267181195264",
        "numerator": "38685626227668133590597632000",
        "expected_fee": "38685626227668133590598",
        "note": "ceil(500 * 1 * 77371252455336267181195264 / 1000000)"
      },
      {
        "description": "2000 bytes, fresh genesis",
        "data_bytes": 2000,
        "fee_rate_num": 1,
        "fee_rate_den": 1000000,
        "shares_out": "77371252455336267181195264",
        "numerator": "154742504910672534362390528000",
        "expected_fee": "154742504910672534362391",
        "note": "ceil(2000 * 77371252455336267181195264 / 1000000)"
      },
      {
        "description": "500 bytes, after 50% shares retired",
        "data_bytes": 500,
        "fee_rate_num": 1,
        "fee_rate_den": 1000000,
        "shares_out": "38685626227668133590597632",
        "numerator": "19342813113834066795298816000",
        "expected_fee": "19342813113834066795299",
        "note": "half the absolute fee, same coin-denominated fee"
      },
      {
        "description": "214 bytes (minimal assignment), fresh genesis",
        "data_bytes": 214,
        "fee_rate_num": 1,
        "fee_rate_den": 1000000,
        "shares_out": "77371252455336267181195264",
        "numerator": "16557448025441961176775786496",
        "expected_fee": "16557448025441961176776",
        "note": "minimal assignment estimate from WireFormat.md §6.3"
      },
      {
        "description": "500 bytes, different fee rate",
        "data_bytes": 500,
        "fee_rate_num": 3,
        "fee_rate_den": 10000000000,
        "shares_out": "77371252455336267181195264",
        "numerator": "116056878683004400771792896000",
        "expected_fee": "11605687868300440078",
        "note": "fee_rate = 3/10^10 (very small rate)"
      }
    ]
  },

  "expiration_hard_cutoff": {
    "_description": "Mode 1: shares fully valid until expiry, then retired. expiry_time = receipt_timestamp + EXPIRY_PERIOD.",
    "vectors": [
      {
        "description": "1-year expiration",
        "receipt_unix_seconds": 1767225600,
        "expiry_period_seconds": 31557600,
        "expiry_unix_seconds": 1798783200,
        "expiry_period_ao": "5964386400000000",
        "note": "31557600 = 365.25 * 86400 (Julian year). Shares valid at 1798783199, expired at 1798783201."
      }
    ]
  },

  "expiration_age_tax": {
